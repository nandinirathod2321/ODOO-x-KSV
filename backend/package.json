{
  "name": "vendorbridge-backend",
  "version": "1.0.0",
  "description": "VendorBridge ERP Backend — Node.js + TypeScript + Prisma + SQLite",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node --watch dist/server.js",
    "start": "node dist/server.js",
    "setup": "npm install && npm run db:push && npm run db:seed",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma db push --force-reset && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.10.1",
    "puppeteer": "^25.1.0",
    "prisma": "^5.0.0",
    "socket.io": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {}
}
