# -----------------------------------------
# VendorBridge Backend — Environment Config
# -----------------------------------------
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server
PORT=8000
NODE_ENV=development

# Database (SQLite — zero config, works out of the box)
DATABASE_URL="file:./dev.db"

# Authentication — change this to a long random string in production
JWT_SECRET="vendorbridge_dev_jwt_secret_change_in_prod"
JWT_EXPIRES_IN="24h"

# Email (optional — leave blank to skip email features)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
