# -----------------------------------------
# VendorBridge Environment Configuration
# -----------------------------------------

# Server
PORT=5000
NODE_ENV=development

# Database Configuration (MySQL)
# Choose the appropriate format for your environment:

# 1. Local / Native MySQL (with password)
# DATABASE_URL="mysql://root:password@localhost:3306/vendorbridge"

# 2. XAMPP MySQL (typically no password)
# DATABASE_URL="mysql://root@localhost:3306/vendorbridge"

# 3. Docker MySQL
# DATABASE_URL="mysql://root:password@db:3306/vendorbridge"

# Active Database URL
DATABASE_URL="mysql://root:password@localhost:3306/vendorbridge"

# Authentication
JWT_SECRET="your_production_ready_jwt_secret_here"
JWT_EXPIRES_IN="24h"

# Email Configuration (Nodemailer)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
